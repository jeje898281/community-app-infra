# Copy to .env.dev and fill in the secrets before running ./deploy-dev.sh

# 📦 PostgreSQL
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
POSTGRES_DB=community

# 🚀 Local service ports
BACKEND_PORT=3000
FRONTEND_PORT=5173

# 🔐 JWT — generate a long random string. Example:
#   openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=replace-with-a-long-random-string

# 💾 Redis (internal container DNS — leave as-is for compose)
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CLUSTER=false

# 🌐 CORS (the origins allowed to call the backend)
CORS_ORIGIN=http://localhost:5173

# 🧭 Frontend → backend dev proxy target (used by Vite)
VITE_API_TARGET=http://backend:3000

# 📧 SMTP — required for the worker to send real email.
# A Gmail App Password (https://myaccount.google.com/apppasswords) works out of the box.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-gmail@gmail.com

# 🗄️ Backend Prisma connection (built from POSTGRES_* above)
DATABASE_URL=postgresql://app:change-me@db:5432/community
